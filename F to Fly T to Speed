local InputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local CCamera = Workspace.CurrentCamera
local Player = Players.LocalPlayer
local Mouse = Player:GetMouse()

getgenv().Velocity = {
    Enabled = false,
    Value = 500,
    Key = "T",
    Flying = {
        Enabled = false,
        Key = "F",
        Value = 5
    },
    Click = {
		Enabled = false,
		Held = false,
        Key = "C",
        Value = 3.1
    }
}

InputService.InputBegan:Connect(function(Input, GameProcessed)
    if GameProcessed then return end
 
    if Input.KeyCode == Enum.KeyCode[getgenv().Velocity.Key] then
        getgenv().Velocity.Enabled = not getgenv().Velocity.Enabled
     
        if getgenv().Velocity.Enabled then
            return
        elseif not getgenv().Velocity.Enabled then
            BreakVelocity()
        end
    elseif Input.KeyCode == Enum.KeyCode[getgenv().Velocity.Flying.Key] then
        if not getgenv().Velocity.Flying.Enabled then
            FLY()
        else
            UNFLY()
            BreakVelocity()
        end
	elseif Input.KeyCode == Enum.KeyCode.C and InputService:IsKeyDown(Enum.KeyCode.LeftAlt) then
        getgenv().Velocity.Click.Enabled = not getgenv().Velocity.Click.Enabled
    end
end)

RunService.Stepped:Connect(function()
    pcall(function()
        if getgenv().Velocity.Enabled then
            Player.Character.HumanoidRootPart.Velocity = Vector3.new(
                Player.Character:FindFirstChild("Humanoid").MoveDirection.X * getgenv().Velocity.Value,
                Player.Character:FindFirstChild("HumanoidRootPart").Velocity.Y - 0.2,
                Player.Character:FindFirstChild("Humanoid").MoveDirection.Z * getgenv().Velocity.Value
            )
        end
     
        if not InputService:GetFocusedTextBox() then
            if InputService:IsKeyDown(Enum.KeyCode.Space) then
                Player.Character:FindFirstChild("Humanoid"):ChangeState(3)
            end
        end
     
        if Player.Character:FindFirstChild("Humanoid"):GetState() == Enum.HumanoidStateType.Ragdoll or
           Player.Character:FindFirstChild("Humanoid"):GetState() == Enum.HumanoidStateType.FallingDown then
            Player.Character:FindFirstChild("Humanoid"):ChangeState(3)
        end

		if getgenv().Velocity.Click.Enabled then
			if not InputService:GetFocusedTextBox() then
				if InputService:IsKeyDown(Enum.KeyCode[getgenv().Velocity.Click.Key]) then
					if not getgenv().Velocity.Click.Held then
						getgenv().Velocity.Click.Held = true
						pcall(function()
							Player.Character:PivotTo(CFrame.new(Mouse.Hit.p + Vector3.new(0, getgenv().Velocity.Click.Value, 0)))
							local LookDirection = Vector3.new(CCamera.CFrame.LookVector.X, 0, CCamera.CFrame.LookVector.Z)
							if LookDirection.Magnitude > 0 then
								LookDirection = LookDirection.Unit
							else
								LookDirection = Vector3.new(0,0,1)
							end
							Player.Character.HumanoidRootPart.CFrame = CFrame.lookAt(
								Player.Character.HumanoidRootPart.Position,
								Player.Character.HumanoidRootPart.Position + LookDirection
							)
							BreakVelocity()
							if Player.Character:FindFirstChildOfClass("Humanoid") then
								Player.Character:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.GettingUp)
							end
						end)
					end
				else
					getgenv().Velocity.Click.Held = false
				end
			end
		end
    end)
end)

local flyKeyDown, flyKeyUp
local FlyConn, CharConn
local FlyBV, FlyBG
local CONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
local lCONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
local SPEED = 0

local function startFly(Char)
    local Humanoid = Char:WaitForChild("Humanoid")
    local HRP = Char:WaitForChild("HumanoidRootPart")
    FlyBG = Instance.new("BodyGyro")
    FlyBG.P = 9e4
    FlyBG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    FlyBG.CFrame = HRP.CFrame
    FlyBG.Parent = HRP
    FlyBV = Instance.new("BodyVelocity")
    FlyBV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    FlyBV.Velocity = Vector3.zero
    FlyBV.Parent = HRP
    Humanoid.PlatformStand = true
end

local function stopFly()
    if flyKeyDown then flyKeyDown:Disconnect() flyKeyDown = nil end
    if flyKeyUp then flyKeyUp:Disconnect() flyKeyUp = nil end
    if FlyBG then FlyBG:Destroy() FlyBG = nil end
    if FlyBV then FlyBV:Destroy() FlyBV = nil end
end

function FLY()
    if getgenv().Velocity.Flying.Enabled then return end
    getgenv().Velocity.Flying.Enabled = true
    local function apply(Char)
        startFly(Char)
    end
    if Player.Character then
        apply(Player.Character)
    end
    CharConn = Player.CharacterAdded:Connect(function(Char)
        if getgenv().Velocity.Flying.Enabled then
            task.wait(0.15)
            apply(Char)
        end
    end)
    flyKeyDown = InputService.InputBegan:Connect(function(Input, GP)
        if GP then return end
        if Input.KeyCode == Enum.KeyCode.W then CONTROL.F = getgenv().Velocity.Flying.Value
        elseif Input.KeyCode == Enum.KeyCode.S then CONTROL.B = -getgenv().Velocity.Flying.Value
        elseif Input.KeyCode == Enum.KeyCode.A then CONTROL.L = -getgenv().Velocity.Flying.Value
        elseif Input.KeyCode == Enum.KeyCode.D then CONTROL.R = getgenv().Velocity.Flying.Value
        elseif Input.KeyCode == Enum.KeyCode.E then CONTROL.Q = getgenv().Velocity.Flying.Value * 2
        elseif Input.KeyCode == Enum.KeyCode.Q then CONTROL.E = -getgenv().Velocity.Flying.Value * 2 end
    end)
    flyKeyUp = InputService.InputEnded:Connect(function(Input)
        if Input.KeyCode == Enum.KeyCode.W then CONTROL.F = 0
        elseif Input.KeyCode == Enum.KeyCode.S then CONTROL.B = 0
        elseif Input.KeyCode == Enum.KeyCode.A then CONTROL.L = 0
        elseif Input.KeyCode == Enum.KeyCode.D then CONTROL.R = 0
        elseif Input.KeyCode == Enum.KeyCode.E then CONTROL.Q = 0
        elseif Input.KeyCode == Enum.KeyCode.Q then CONTROL.E = 0 end
    end)
    FlyConn = RunService.Stepped:Connect(function()
        if not getgenv().Velocity.Flying.Enabled then return end
        if not FlyBV or not FlyBG then return end
        local Cam = Workspace.CurrentCamera
        if CONTROL.L + CONTROL.R ~= 0 or CONTROL.F + CONTROL.B ~= 0 or CONTROL.Q + CONTROL.E ~= 0 then
            SPEED = 50
        else
            SPEED = 0
        end
        if SPEED ~= 0 then
            FlyBV.Velocity =
                ((Cam.CFrame.LookVector * (CONTROL.F + CONTROL.B)) +
                ((Cam.CFrame * CFrame.new(
                    CONTROL.L + CONTROL.R,
                    (CONTROL.F + CONTROL.B + CONTROL.Q + CONTROL.E) * 0.2,
                    0
                ).p) - Cam.CFrame.p)) * SPEED
            lCONTROL = CONTROL
        else
            FlyBV.Velocity = Vector3.zero
        end
        FlyBG.CFrame = Cam.CFrame
    end)
end

function BreakVelocity()
    pcall(function()
        if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
            Player.Character.HumanoidRootPart.Velocity = Vector3.zero
        end
    end)
end

function UNFLY()
    getgenv().Velocity.Flying.Enabled = false
    if FlyConn then FlyConn:Disconnect() FlyConn = nil end
    if CharConn then CharConn:Disconnect() CharConn = nil end
    CONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
    lCONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
    SPEED = 0
    stopFly()
 
    pcall(function()
        if Player.Character and Player.Character:FindFirstChildOfClass("Humanoid") then
            local hum = Player.Character:FindFirstChildOfClass("Humanoid")
            hum.PlatformStand = false
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end)
    pcall(function()
        if Player.Character then
            local hrp = Player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local bg = hrp:FindFirstChildOfClass("BodyGyro")
                if bg then bg:Destroy() end
                local bv = hrp:FindFirstChildOfClass("BodyVelocity")
                if bv then bv:Destroy() end
            end
        end
    end)
end

_G.CameraSettings = {
    Sensitivity = 1,
    CameraDistance = 10,
    HideCharacterZoom = 0.5,
    Pitch = 0,
    Yaw = 0,
    ZoomStep = 7,
    ZoomTweenTime = 0,
    ZoomMin = 0.5,
    ZoomMax = 500,
    ZoomEasingStyle = Enum.EasingStyle.Quint,
    ZoomEasingDirection = Enum.EasingDirection.Out
}

local rotating = false
local zoomTween
local isInFirstPersonLock = false

CCamera.CameraType = Enum.CameraType.Scriptable

do
    local look = CCamera.CFrame.LookVector
    _G.CameraSettings.Yaw = math.atan2(-look.X, -look.Z)
    _G.CameraSettings.Pitch = math.asin(look.Y)
end

InputService.InputBegan:Connect(function(Input, GP)
    if GP then return end
    if Input.UserInputType == Enum.UserInputType.MouseButton2 then
        rotating = true
        InputService.MouseBehavior = Enum.MouseBehavior.LockCenter
    end
end)

InputService.InputEnded:Connect(function(Input)
    if Input.UserInputType == Enum.UserInputType.MouseButton2 then
        rotating = false
        InputService.MouseBehavior = Enum.MouseBehavior.Default
    end
end)

InputService.InputChanged:Connect(function(inp)
    if rotating and inp.UserInputType == Enum.UserInputType.MouseMovement then
        local invert = math.cos(_G.CameraSettings.Pitch) < 0 and -1 or 1
        _G.CameraSettings.Yaw -= inp.Delta.X * _G.CameraSettings.Sensitivity * 0.01 * invert
        _G.CameraSettings.Pitch -= inp.Delta.Y * _G.CameraSettings.Sensitivity * 0.01
    end
end)

InputService.InputChanged:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType ~= Enum.UserInputType.MouseWheel then return end
    if InputService:GetFocusedTextBox() then return end

    local scrollDir = -input.Position.Z
    local current = _G.CameraSettings.CameraDistance
    local target = math.clamp(current + (scrollDir * _G.CameraSettings.ZoomStep), _G.CameraSettings.ZoomMin, _G.CameraSettings.ZoomMax)

    if zoomTween and typeof(zoomTween) == "Instance" and zoomTween:IsA("Tween") then
        pcall(zoomTween.Cancel, zoomTween)
    end

    local success, newTween = pcall(function()
        return TweenService:Create(
            _G.CameraSettings,
            TweenInfo.new(
                _G.CameraSettings.ZoomTweenTime,
                _G.CameraSettings.ZoomEasingStyle,
                _G.CameraSettings.ZoomEasingDirection
            ),
            { CameraDistance = target }
        )
    end)

    if success and newTween then
        zoomTween = newTween
        pcall(zoomTween.Play, zoomTween)
    else
        _G.CameraSettings.CameraDistance = target
    end
end)

RunService.RenderStepped:Connect(function()
    local Char = Player.Character
    if not Char or not Char:FindFirstChild("Head") then return end
    local Head = Char.Head
    local hrp = Char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    CCamera.CFrame =
        CFrame.new(Head.Position)
        * CFrame.Angles(0, _G.CameraSettings.Yaw, 0)
        * CFrame.Angles(_G.CameraSettings.Pitch, 0, 0)
        * CFrame.new(0, 0, _G.CameraSettings.CameraDistance)

    local isFullyZoomed = _G.CameraSettings.CameraDistance <= _G.CameraSettings.HideCharacterZoom

    for _, v in ipairs(Char:GetDescendants()) do
        if v:IsA("BasePart") then
            v.LocalTransparencyModifier = isFullyZoomed and 1 or 0
        end
    end

    if isFullyZoomed then
        if not isInFirstPersonLock then
            isInFirstPersonLock = true
            InputService.MouseBehavior = Enum.MouseBehavior.LockCenter
        end

        local camLook = CCamera.CFrame.LookVector
        local lookDir = Vector3.new(camLook.X, 0, camLook.Z).Unit
        if lookDir.Magnitude > 0 then
            hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + lookDir)
        end
    else
        if isInFirstPersonLock then
            isInFirstPersonLock = false
            InputService.MouseBehavior = Enum.MouseBehavior.Default
        end
    end
end)

local SHIFTLOCK_CURSOR = "rbxasset://textures/MouseLockedCursor.png"

RunService.RenderStepped:Connect(function()
    if Mouse.Icon == SHIFTLOCK_CURSOR then
        rotating = true
        InputService.MouseBehavior = Enum.MouseBehavior.LockCenter
      
        local char = Player.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
      
        local camCF = CCamera.CFrame
        local camLook = camCF.LookVector
      
        if getgenv().Velocity.Flying.Enabled and FlyBG then
            FlyBG.CFrame = camCF
        else
            local lookDir = Vector3.new(camLook.X, 0, camLook.Z).Unit
            if lookDir.Magnitude > 0 then
                hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + lookDir)
            end
        end
    end
end)
